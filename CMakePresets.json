{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_ASAN": "OFF",
        "ENABLE_TSAN": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_ASAN": "OFF",
        "ENABLE_TSAN": "OFF"
      }
    },
    {
      "name": "asan",
      "displayName": "ASan Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_ASAN": "ON",
        "ENABLE_TSAN": "OFF"
      }
    },
    {
      "name": "tsan",
      "displayName": "TSan Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/tsan",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_ASAN": "OFF",
        "ENABLE_TSAN": "ON"
      }
    },
    {
      "name": "engine-only",
      "displayName": "Engine Only (no GUI)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/engine-only",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "THOTH_BUILD_GUI": "OFF",
        "THOTH_BUILD_ENGINE": "ON",
        "ENABLE_ASAN": "OFF",
        "ENABLE_TSAN": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "displayName": "Build Debug",
      "configurePreset": "debug"
    },
    {
      "name": "build-release",
      "displayName": "Build Release",
      "configurePreset": "release"
    },
    {
      "name": "build-asan",
      "displayName": "Build ASan",
      "configurePreset": "asan"
    },
    {
      "name": "build-tsan",
      "displayName": "Build TSan",
      "configurePreset": "tsan"
    },
    {
      "name": "build-engine-only",
      "displayName": "Build Engine Only",
      "configurePreset": "engine-only"
    }
  ]
}
